OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
NOVEL_AGENT_MODEL=gpt-4o-mini

# Optional: vector memory / RAG
# Leave NOVEL_AGENT_EMBEDDING_MODEL empty to use deterministic local hash embeddings.
# For production, set an OpenAI-compatible embedding model and match its dimensions.
NOVEL_AGENT_MEMORY_BACKEND=local
NOVEL_AGENT_EMBEDDING_MODEL=
NOVEL_AGENT_EMBEDDING_DIMENSIONS=256

# Optional: pgvector backend. Requires: pip install -e '.[pgvector]'
NOVEL_AGENT_PGVECTOR_DSN=postgresql://user:replace-me@localhost:5432/novel_agent
NOVEL_AGENT_PGVECTOR_TABLE=novel_memory
